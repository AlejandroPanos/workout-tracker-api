<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile - Workout Tracker</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-gray-50">
    <%- include('../includes/logged-nav.ejs') %>

    <div class="container mx-auto px-4 py-8">
      <div class="max-w-4xl mx-auto">
        <!-- Profile Header -->
        <div class="bg-white rounded-lg shadow-md p-8 mb-6">
          <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
            <!-- Profile Image -->
            <img
              src="<%= profileUser.profilePicture %>"
              alt="Profile"
              class="w-32 h-32 rounded-full object-cover border-4 border-blue-600"
            />

            <!-- Profile Info -->
            <div class="flex-1 text-center md:text-left">
              <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= profileUser.name %></h1>
              <p class="text-gray-600 mb-4"><%= profileUser.email %></p>
              <div class="flex items-center justify-center md:justify-start gap-2">
                <span
                  class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold"
                >
                  <%= profileUser.role %>
                </span>
                <span class="text-gray-600 text-sm">
                  Member since <%= profileUser.createdAt.toISOString().split('T')[0] %>
                </span>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-2">
              <a
                href="/profile/edit/<%= profileUser._id %>"
                class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors"
              >
                Edit Profile
              </a>
              <form action="/api/users/<%= profileUser._id %>/delete" method="POST">
                <button
                  type="submit"
                  class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors"
                >
                  Delete Account
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- My Workouts -->

        <div class="bg-white rounded-lg shadow-md p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-gray-900">My Workouts</h2>
            <a
              href="/workouts/create"
              class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors"
            >
              + Add Workout
            </a>
          </div>

          <!-- Workout List -->
          <div class="space-y-4">
            <% if (profileUser.workouts.length > 0) { %> <% profileUser.workouts.forEach(workout =>
            { %>
            <!-- Workout Item -->
            <div
              class="border border-gray-200 rounded-lg p-4 hover:border-blue-500 transition-colors"
            >
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-gray-900 mb-1"><%= workout.name %></h3>
                  <p class="text-gray-600 text-sm mb-2"><%= workout.description %></p>
                  <div class="flex items-center gap-4 text-sm">
                    <span class="text-gray-600"> ⏱️ <%= workout.duration %> min </span>
                    <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs font-semibold">
                      <%= workout.difficulty %>
                    </span>
                  </div>
                </div>
                <a
                  href="/workouts/<%= workout._id %>"
                  class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-900 rounded-lg transition-colors"
                >
                  View Details
                </a>
              </div>
            </div>
            <% }) %> <% } else { %>
            <!-- Empty State -->
            <div class="text-center py-12">
              <p class="text-gray-600 mb-4">No workouts added yet</p>
              <a href="/workouts/create" class="text-blue-600 hover:text-blue-700 font-semibold">
                Create your first workout
              </a>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
