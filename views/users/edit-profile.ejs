<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Profile - Workout Tracker</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-gray-50">
    <%- include('../includes/logged-nav.ejs') %>

    <div class="container mx-auto px-4 py-8">
      <div class="max-w-2xl mx-auto">
        <!-- Back Button -->
        <a
          href="/profile/<%= profileUser._id %>"
          class="inline-flex items-center text-blue-600 hover:text-blue-700 mb-6"
        >
          ← Back to Profile
        </a>

        <!-- Edit Form -->
        <div class="bg-white rounded-lg shadow-md p-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-6">Edit Profile</h1>

          <form
            action="/api/users/<%= profileUser._id %>/edit"
            method="POST"
            enctype="multipart/form-data"
          >
            <!-- Current Profile Image -->
            <div class="mb-6 text-center">
              <img
                src="<%= profileUser.profilePicture %>"
                alt="Current Profile"
                class="w-32 h-32 rounded-full object-cover border-4 border-blue-600 mx-auto mb-4"
              />
            </div>

            <!-- Username -->
            <div class="mb-4">
              <label for="username" class="block text-sm font-medium text-gray-700 mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                value="<%= profileUser.name %>"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <!-- Username -->
            <div class="mb-4">
              <label for="username" class="block text-sm font-medium text-gray-700 mb-2">
                Username
              </label>
              <input
                type="text"
                id="username"
                name="username"
                value="<%= profileUser.username %>"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <!-- Email -->
            <div class="mb-4">
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                value="<%= profileUser.email %>"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <!-- New Password -->
            <div class="mb-4">
              <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
                New Password (leave blank to keep current)
              </label>
              <input
                type="password"
                id="password"
                name="password"
                minlength="6"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                placeholder="••••••••"
              />
            </div>

            <!-- New Profile Image -->
            <div class="mb-6">
              <label for="profilePicture" class="block text-sm font-medium text-gray-700 mb-2">
                Update Profile Picture
              </label>
              <input
                type="file"
                id="profilePicture"
                name="profilePicture"
                accept="image/*"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
              <p class="text-xs text-gray-500 mt-1">JPG, PNG or JPEG (max 5MB)</p>
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-4">
              <button
                type="submit"
                class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors"
              >
                Save Changes
              </button>
              <a
                href="/profile"
                class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-900 font-semibold py-3 rounded-lg transition-colors text-center"
              >
                Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>
