<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Workout Details - Workout Tracker</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-gray-50">
    <%- include('../includes/logged-nav.ejs') %>

    <div class="container mx-auto px-4 py-8">
      <div class="max-w-4xl mx-auto">
        <!-- Back Button -->
        <a href="/workouts" class="inline-flex items-center text-blue-600 hover:text-blue-700 mb-6">
          ← Back to Workouts
        </a>

        <!-- Workout Header -->
        <div class="bg-white rounded-lg shadow-md p-8 mb-6">
          <div class="flex flex-col md:flex-row items-start justify-between mb-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-4">
                <span
                  class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold"
                >
                  <%= workout.difficulty %>
                </span>
                <span class="text-gray-600"> ⏱️ <%= workout.duration %> minutes </span>
              </div>

              <h1 class="text-4xl font-bold text-gray-900 mb-3"><%= workout.name %></h1>

              <p class="text-gray-600 text-lg mb-4"><%= workout.description %></p>

              <div class="flex items-center gap-3 text-sm text-gray-500">
                <span>Created by @<%= profileUser.username %></span>
                <span>•</span>
                <span>Created on <%= workout.createdAt.toISOString().split('T')[0] %></span>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-2 mt-4 md:mt-0">
              <% if (user._id.toString() === profileUser._id.toString() || user.role === 'admin') {
              %>
              <a
                href="/workouts/<%= workout._id %>/edit"
                class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors"
              >
                Edit
              </a>
              <form action="/api/workouts/<%= workout._id %>/delete" method="POST">
                <button
                  type="submit"
                  class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors"
                >
                  Delete
                </button>
              </form>
              <% } %>
            </div>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-6 border-t border-gray-200">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl font-bold text-blue-600 mb-1">
                <%= workout.exercises.length %>
              </div>
              <div class="text-sm text-gray-600">Total Exercises</div>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl font-bold text-green-600 mb-1"><%= workout.duration %></div>
              <div class="text-sm text-gray-600">Minutes</div>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <div class="text-3xl font-bold text-purple-600 mb-1"><%= workout.difficulty %></div>
              <div class="text-sm text-gray-600">Difficulty Level</div>
            </div>
          </div>
        </div>

        <!-- Exercise List -->
        <div class="bg-white rounded-lg shadow-md p-8 mb-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Exercise List</h2>

          <div class="space-y-4">
            <% workout.exercises.forEach((e, i) => { %>
            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
              <div
                class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold flex-shrink-0"
              >
                <%= i + 1 %>
              </div>
              <div class="flex-1">
                <h3 class="font-semibold text-gray-900"><%= e %></h3>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
